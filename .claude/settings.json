{
  "statusLine": {
    "type": "command",
    "command": "bash tools/dm-statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tool-state-log.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-autosave.sh"
          }
        ]
      }
    ]
  }
}
